# 単一アカウント運用時のみ使う (refresh_session.mjs / post 系 CLI で参照)
NOTE_EMAIL=your-email@example.com
NOTE_PASSWORD=your-password

# (任意) 直接 cookies を渡す。設定されてれば session.json より優先
# NOTE_COOKIES=_note_session_v5=xxxxxxxxxxxx

# (任意) アカウントファイルのパス上書き. デフォルトは <package>/accounts/note_accounts.json
# NOTE_ACCOUNTS_PATH=/path/to/note_accounts.json
