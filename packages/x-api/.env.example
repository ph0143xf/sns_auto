# x-api 環境変数 (オプション)

# アカウントファイルパス上書き (デフォルト: ./accounts/x_accounts.json)
# X_ACCOUNTS_PATH=/path/to/x_accounts.json

# env credentials 自動ログイン用
# アカウント名 "my_account" の場合の env 名 (account 名を大文字化 + 非英数字を _)
# X_LOGIN_USERNAME_MY_ACCOUNT=your_x_handle
# X_LOGIN_PASSWORD_MY_ACCOUNT=your_password

# fallback (アカウント別 env が無い時に使われる)
# X_LOGIN_USERNAME=your_x_handle
# X_LOGIN_PASSWORD=your_password
